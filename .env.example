# Copiar para .env na raiz (não commitar .env com segredos reais).
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:8080

# JWT / webhook (gerar valores aleatórios ≥ 32 chars)
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM_STRING
PIX_WEBHOOK_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM_STRING

# Stub = sem PSP real; Production = exige adaptador + PIX_PSP_* (ver código)
PIX_MODE=Stub

# Postgres local (docker-compose)
DATABASE_URL_IDENTITY=Host=localhost;Port=5432;Database=parking_identity;Username=parking;Password=parking_dev
DATABASE_URL_AUDIT=Host=localhost;Port=5432;Database=parking_audit;Username=parking;Password=parking_dev

# {uuid} sem hífens — usado ao abrir conexão do tenant
TENANT_DATABASE_URL_TEMPLATE=Host=localhost;Port=5432;Database=parking_{uuid};Username=parking;Password=parking_dev

# Web Vue (Vite)
CORS_ORIGINS=http://localhost:5173

# Apenas E2E/CI: cria super@test.com / Super!12345 no identity se ausente
E2E_SEED=0

# Jobs em background (opcional): intervalo em segundos
# PIX_EXPIRY_JOB_SECONDS=60
# DATA_RETENTION_JOB_SECONDS=3600
