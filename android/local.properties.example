# Copie para android/local.properties (gitignore) e ajuste o caminho.
# Android Studio costuma usar: %LOCALAPPDATA%\Android\Sdk
sdk.dir=C:/Users/SEU_USUARIO/AppData/Local/Android/Sdk

# Opcional — debug apenas: URL da API (terminar em /api/v1).
# Omita para emulador (usa http://10.0.2.2:8080/api/v1).
# Telemóvel + API no PC (LAN): IP do PC. Telemóvel + API em produção: HTTPS abaixo.
#parking.api.base=http://192.168.1.50:8080/api/v1

# Produção (build release): URL embutida no APK (BuildConfig.API_BASE).
# Mesmo valor que VITE_API_BASE no deploy do frontend (ex. docs/DEPLOY-AZURE.md).
#parking.api.production=https://SEU-APP.azurecontainerapps.io/api/v1
#
# Alternativa sem editar este ficheiro: na raiz do repo, executar
#   .\scripts\build-android-release-apk.ps1 -ProductionApiUrl "https://.../api/v1"
# ou definir a variável de ambiente PARKING_API_PRODUCTION antes do script / gradlew.

# Atalho: APK debug no telemóvel só contra produção — use a mesma URL em parking.api.base:
#parking.api.base=https://SEU-APP.azurecontainerapps.io/api/v1
